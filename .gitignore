# =============================================
# MYCORP. FRONTEND - MASTER GITIGNORE
# =============================================

# 1. DEPENDENCIES
# ---------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# 2. NEXT.JS SPECIFIC
# ---------------------------------------------
/.next/
/out/
/build
/dist
/chunks
*.tsbuildinfo
next-env.d.ts

# 3. ENVIRONMENT SECRETS (CRITICAL)
# ---------------------------------------------
# We ignore all .env files to protect your API keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# 4. TESTING & COVERAGE
# ---------------------------------------------
/coverage
/__tests__/*.log

# 5. OS & IDE JUNK
# ---------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 6. LOGS & DEBUGGING
# ---------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs
*.log

# 7. VERCEL & DEPLOYMENT
# ---------------------------------------------
.vercel
.turbo